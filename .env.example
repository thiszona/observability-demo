# Chaos knobs. Set them per service in compose.yaml. All default to OFF, so a
# service with none of these set behaves normally.

CHAOS_ERROR_RATE=0.2      # fraction of requests to fail, 0.0..1.0 (demo default: payment)
CHAOS_ERROR_STATUS=500    # status code returned on an injected error
CHAOS_LATENCY=250ms       # fixed delay added before handling (e.g. on fraud)
INJECT_INTERVAL=500ms     # how often the injector fires a request
